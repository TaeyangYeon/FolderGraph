<UserControl x:Class="FolderGraph.Views.GraphCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                BorderBrush="#33000000"
                                BorderThickness="1" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FFFFFF" />
                                <Setter TargetName="bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="Viewport"
          Background="#0F172A"
          ClipToBounds="True"
          MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
          MouseMove="Viewport_MouseMove"
          MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
          MouseRightButtonUp="Viewport_MouseRightButtonUp"
          MouseWheel="Viewport_MouseWheel">

        <!-- RootCanvas: 줌/이동 변환을 담는다 -->
        <Canvas x:Name="RootCanvas" Background="Transparent">
            <Canvas.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="PanTransform" X="0" Y="0" />
                </TransformGroup>
            </Canvas.RenderTransform>

            <!-- GraphLayer: 변환이 적용되지 않는 그래프 콘텐츠. 미니맵이 이걸 비춘다 -->
            <Grid x:Name="GraphLayer">
                <!-- 엣지 레이어 -->
                <ItemsControl ItemsSource="{Binding Edges}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                  X2="{Binding X2}" Y2="{Binding Y2}"
                                  Stroke="#374151" StrokeThickness="1"
                                  Opacity="{Binding Opacity}"
                                  IsHitTestVisible="False" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 노드 레이어 -->
                <ItemsControl ItemsSource="{Binding Nodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="{Binding Diameter}"
                                     Height="{Binding Diameter}"
                                     Fill="{Binding Fill}"
                                     Opacity="{Binding Opacity}"
                                     ToolTip="{Binding DisplayLabel}">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Stroke" Value="{Binding StrokeBrush}" />
                                        <Setter Property="StrokeThickness" Value="{Binding StrokeThicknessValue}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                <Setter Property="Stroke" Value="#3B82F6" />
                                                <Setter Property="StrokeThickness" Value="3" />
                                                <Setter Property="StrokeDashArray" Value="3 2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Canvas>

        <!-- 미니맵 오버레이 (우하단) -->
        <Border x:Name="MinimapPanel"
                Width="200" Height="140"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="12"
                Background="#CC0F172A" BorderBrush="#334155" BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding ShowMinimap, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Rectangle x:Name="MinimapContent"
                           Margin="3"
                           MouseLeftButtonDown="Minimap_MouseLeftButtonDown"
                           MouseMove="Minimap_MouseMove"
                           MouseLeftButtonUp="Minimap_MouseLeftButtonUp"
                           Cursor="Hand">
                    <Rectangle.Fill>
                        <VisualBrush Visual="{Binding ElementName=GraphLayer}" Stretch="Uniform" />
                    </Rectangle.Fill>
                </Rectangle>
                <!-- 현재 보이는 영역 표시 -->
                <Canvas IsHitTestVisible="False" Margin="3">
                    <Rectangle x:Name="MinimapViewport"
                               Stroke="#38BDF8" StrokeThickness="1.5"
                               Fill="#3338BDF8" />
                </Canvas>

                <!-- 닫기 버튼 -->
                <Button Content="✕"
                        Width="18" Height="18"
                        Padding="0"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,2,2,0"
                        Foreground="#CBD5E1"
                        Background="#1E293B"
                        BorderBrush="#334155"
                        ToolTip="미니맵 닫기"
                        Command="{Binding ToggleMinimapCommand}" />
            </Grid>
        </Border>

        <!-- 색상 팔레트 팝업 -->
        <Popup x:Name="PalettePopup"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=Viewport}"
               AllowsTransparency="True"
               StaysOpen="False"
               IsOpen="{Binding IsPaletteOpen, Mode=TwoWay}">
            <Border Background="#1E293B" CornerRadius="10" Padding="8"
                    BorderBrush="#334155" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.5" />
                </Border.Effect>
                <StackPanel Width="148">
                    <ItemsControl ItemsSource="{Binding PaletteColors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SwatchButton}"
                                        Background="{Binding Brush}"
                                        Command="{Binding DataContext.PickColorCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="회색으로 초기화"
                            Margin="3,6,3,2" Padding="6,4"
                            Foreground="#CBD5E1" Background="#0F172A" BorderBrush="#334155"
                            Command="{Binding ResetColorCommand}" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
