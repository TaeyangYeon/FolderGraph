<UserControl x:Class="FolderGraph.Views.ToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="56" d:DesignWidth="1000">

    <Border Padding="10,8" Background="#1E293B">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1.4*" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 경로 입력 -->
            <TextBox Grid.Column="0"
                     VerticalContentAlignment="Center"
                     Margin="0,0,8,0"
                     Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="스캔할 폴더 경로" />

            <!-- 불러오기 -->
            <Button Grid.Column="1"
                    Content="불러오기"
                    Padding="14,4"
                    Margin="0,0,16,0"
                    Command="{Binding LoadCommand}" />

            <!-- 검색창 -->
            <Grid Grid.Column="2" Margin="0,0,4,0">
                <TextBox x:Name="SearchBox"
                         VerticalContentAlignment="Center"
                         Padding="4,0,52,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="파일/폴더 이름 검색 (Esc로 지우기)">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding ClearSearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <!-- 검색어 없을 때 안내 -->
                <TextBlock Text="🔍 검색"
                           Foreground="#64748B"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSearchText}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <!-- 매칭 수 -->
                <TextBlock Foreground="#38BDF8"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,8,0"
                           Text="{Binding MatchCount, StringFormat={}{0}개}"
                           Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <!-- 검색 지우기 -->
            <Button Grid.Column="3"
                    Content="✕"
                    Padding="8,4"
                    Margin="0,0,16,0"
                    ToolTip="검색 지우기"
                    Command="{Binding ClearSearchCommand}"
                    Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}" />

            <!-- 깊이 슬라이더 -->
            <StackPanel Grid.Column="4" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="깊이" Foreground="#CBD5E1"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <Slider Width="110" VerticalAlignment="Center"
                        Minimum="{Binding MinDepth}"
                        Maximum="{Binding MaxDepth}"
                        Value="{Binding Depth}"
                        IsSnapToTickEnabled="True"
                        TickFrequency="1" />
                <TextBlock Text="{Binding Depth}" Foreground="#CBD5E1"
                           VerticalAlignment="Center" Margin="6,0,0,0" Width="18" />
            </StackPanel>

            <!-- 숨김 표시 체크박스 -->
            <CheckBox Grid.Column="5"
                      Content="숨김 표시"
                      Foreground="#CBD5E1"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0"
                      IsChecked="{Binding IncludeHidden}" />

            <!-- PNG 내보내기 -->
            <StackPanel Grid.Column="6" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                <Button Content="PNG 내보내기"
                        Padding="10,4"
                        ToolTip="현재 보이는 3D 그래프를 PNG로 저장"
                        Command="{Binding ExportImageCommand}" />
            </StackPanel>

            <!-- 진행 표시 -->
            <TextBlock Grid.Column="7"
                       Text="스캔 중..."
                       Foreground="#93C5FD"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Border>
</UserControl>
