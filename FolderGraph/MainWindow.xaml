<mah:MetroWindow x:Class="FolderGraph.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:views="clr-namespace:FolderGraph.Views"
                 Title="FolderGraph" Height="700" Width="1100"
                 WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <views:ToolbarView Grid.Row="0" />

        <!-- 중앙 그래프 캔버스 -->
        <views:GraphCanvasView Grid.Row="1" />

        <!-- 하단 상태바 -->
        <Border Grid.Row="2" Background="#1E293B" Padding="10,4">
            <TextBlock Text="{Binding StatusText}" Foreground="#CBD5E1" />
        </Border>
    </Grid>
</mah:MetroWindow>
